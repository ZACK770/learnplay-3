rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.userId is string 
        && data.userId == request.auth.uid
        && data.aiGenerationsLeft is int
        && data.aiGenerationsLeft >= 0;
    }

    function isValidSession(data) {
      return data.userId is string 
        && data.userId == request.auth.uid
        && data.gameId is string
        && data.score is int
        && data.completedAt == request.time;
    }

    function isValidDataset(data) {
      return data.authorId is string
        && data.authorId == request.auth.uid
        && data.content != null
        && data.gameType is string;
    }

    // --- Collections ---

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['aiGenerationsLeft', 'displayName', 'photoURL', 'totalXP'])
        );
    }

    // Datasets
    match /datasets/{datasetId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn() && isOwner(incoming().authorId) && isValidDataset(incoming());
      allow update: if isSignedIn() && isOwner(existing().authorId) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'content', 'isPublic']);
      allow delete: if isSignedIn() && isOwner(existing().authorId);
    }

    // Sessions
    match /sessions/{sessionId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid; 
      allow create: if isSignedIn() && isOwner(incoming().userId); // Simplified for debug sync
    }

    // Debug Logs
    match /debug_logs/{logId} {
      allow create: if true; // Allow logging even if auth fails
      allow read: if isSignedIn() && request.auth.token.email == 'A0527698420@gmail.com';
    }

    // Connection Test
    match /test/connection {
      allow get: if true;
    }
  }
}
